# Database (Supabase — use the Transaction pooler URL, port 6543)
DATABASE_URL=postgresql://postgres.xxxx:password@aws-1-ap-northeast-2.pooler.supabase.com:6543/postgres

# Supabase project (for file storage — PDF/MD uploads)
# SUPABASE_URL: Settings → API → Project URL
# SUPABASE_SECRET_KEY: Settings → API → secret key (previously called service_role)
# Create a public bucket named "source-files" in Storage before first use
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SECRET_KEY=sb_secret_...

# LLM Provider — swap between local Ollama and cloud OpenRouter with these three vars:
#
# Local (Ollama):
#   OPENAI_BASE_URL=http://localhost:11434/v1
#   LLM_MODEL_NAME=llama3:8b
#   LLM_API_KEY=ollama
#
# Cloud (OpenRouter):
#   OPENAI_BASE_URL=https://openrouter.ai/api/v1
#   LLM_MODEL_NAME=openrouter/free
#   LLM_API_KEY=sk-or-...
OPENAI_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL_NAME=llama3:8b
LLM_API_KEY=sk-or-your-openrouter-key

# Pipeline debug logging (set to "true" to enable, omit or "false" for production)
DEBUG_LOGS=false
